# Discord Bot Configuration
BOT_TOKEN=sentiguard_bot_token_buraya
CLIENT_ID=sentiguard_application_id
GEMINI_API_KEY=

# Logging
LOG_LEVEL=INFO

# ============================================
# GÜVENLIK AYARLARI - Website İletişimi
# ============================================

# Dashboard URL (bot verilerini göndereceği adres)
DASHBOARD_URL=http://localhost:3000

# MASTER_SECRET - Dashboard ile aynı olmalı!
# Bu anahtarı dashboard/.env dosyasından alın
# Örnek: MASTER_SECRET=abc123...
MASTER_SECRET=

# Bot adı (otomatik algılanır, gerekirse değiştirin)
# BOT_NAME=sentiguard
