# Dashboard Configuration
DASHBOARD_PORT=3000

# ============================================
# GÜVENLIK AYARLARI
# ============================================

# Bot-Websitesi iletişimi için paylaşılan gizli anahtar
# Bu anahtarı hiçbir zaman paylaşmayın!
# Örnek: MASTER_SECRET=super_gizli_anahtar_32_karakter
MASTER_SECRET=

# Discord OAuth2 Ayarları (ileride eklenecek)
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# DISCORD_REDIRECT_URI=http://localhost:3000/auth/callback

# Rate Limiting
# API_RATE_LIMIT=60

# Admin kullanıcı ID'leri (virgülle ayrılmış)
# ADMIN_IDS=123456789,987654321
